-----------------------------------------------------------
-- ASSET PLAYGROUND HEARTBEAT
-----------------------------------------------------------
RunService.Heartbeat:Connect(function(dt)
    if not apActive then return end
    local targetRoot
    if apTargetName=="" or apTargetName==lp.Name:lower() then
        targetRoot=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    else
        for _,p in ipairs(Players:GetPlayers()) do
            if p.Name:lower():find(apTargetName) or (p.DisplayName and p.DisplayName:lower():find(apTargetName)) then
                targetRoot=p.Character and p.Character:FindFirstChild("HumanoidRootPart") break
            end
        end
    end
    if not targetRoot then return end

    table.insert(apPathBuffer,1,targetRoot.CFrame)
    if #apPathBuffer>300 then table.remove(apPathBuffer,#apPathBuffer) end

    apAngle=apAngle+(dt*apOrbitSpd)
    apGuillTimer=(apGuillTimer+dt)%3

    local f=getMyPlateFolder() if not f then return end
    local parts={}
    for _,v in ipairs(f:GetDescendants()) do
        if v:IsA("BasePart") and v.Name~="Plate" and not v.Name:lower():find("spawn") then
            v.Anchored=false v.CanCollide=false v.Velocity=Vector3.zero
            for _,j in ipairs(v:GetJoints()) do
                if j.Part0==f:FindFirstChild("Plate") or j.Part1==f:FindFirstChild("Plate") then j:Destroy() end
            end
            table.insert(parts,v)
        end
    end

    local mode=apModes[apModeIdx]
    local myRoot=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    local isSelf=(apTargetName=="" or apTargetName==lp.Name:lower())

    for i,part in ipairs(parts) do
        local pa=apAngle+(i*((math.pi*2)/#parts))
        local x,z=math.cos(pa),math.sin(pa)
        local cf=targetRoot.CFrame
        local finalCF

        if mode=="Snake" then
            local idx=math.min((i*8)+5,#apPathBuffer)
            local tpCF=apPathBuffer[idx] or apPathBuffer[#apPathBuffer] or cf
            finalCF=tpCF*CFrame.new(math.sin(apAngle+(i*0.8))*(apOrbitR*0.25),0,0)
        elseif mode=="Guillotine" then
            local sp=(apGuillTimer>2.5) and (3-apGuillTimer)*2 or 1
            local yP=(sp<0.2) and 1.5 or (apHeight*sp)
            finalCF=cf*CFrame.new(x*apOrbitR,yP,z*apOrbitR)
        elseif mode=="BlackHole" then
            local pulse=(math.sin(apAngle*2)+1)/2
            finalCF=cf*CFrame.new(x*(pulse*apOrbitR),(math.cos(apAngle+i)*2),z*(pulse*apOrbitR))
        elseif mode=="Dish" and myRoot then
            local dishLookAt
            if isSelf then dishLookAt=targetRoot.CFrame*CFrame.new(0,0,-10)
            elseif apRotation then
                local op=targetRoot.Position+Vector3.new(math.cos(apAngle)*apOrbitR,0,math.sin(apAngle)*apOrbitR)
                dishLookAt=CFrame.lookAt(op,targetRoot.Position)
            else
                local dir=(myRoot.Position-targetRoot.Position).Unit
                dishLookAt=CFrame.lookAt(targetRoot.Position+(dir*8),myRoot.Position)
            end
            local row2,col2=(i-1)%4,math.floor((i-1)/4)
            finalCF=dishLookAt*CFrame.new((row2*4)-6,(col2*4),0)
        else
            local off
            if mode=="Flat" then off=CFrame.new(x*apOrbitR,1.5,z*apOrbitR)
            elseif mode=="Ferris" then off=CFrame.new(x*apOrbitR,z*apOrbitR+2,-8)
            elseif mode=="Spiral" then off=CFrame.new(x*apOrbitR,math.sin(pa+(i*0.5))*(apHeight/4)+2,z*apOrbitR)
            elseif mode=="Storm" then
                local hp=i/#parts
                off=CFrame.new(x*(hp*apOrbitR+3),(hp*apHeight)-(apHeight/2),z*(hp*apOrbitR+3))
            elseif mode=="Pulse" then
                local p2=math.sin(apAngle*0.5)*(apOrbitR*0.5)
                off=CFrame.new(x*(apOrbitR+p2),1.5,z*(apOrbitR+p2))
            else off=CFrame.new(x*apOrbitR,1.5,z*apOrbitR) end
            finalCF=cf*off
        end

        local partRot=(apRotation and mode~="Dish") and CFrame.Angles(apAngle,apAngle*0.5,apAngle*0.2) or CFrame.new()
        part.CFrame=finalCF*partRot
    end
end)

