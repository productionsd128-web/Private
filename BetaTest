local function fireVoidStamp(target)
    if isLocking or not target then return end
    isLocking=true
    local plate=getMyPlatePart()
    if plate then
        local vCF=plate.CFrame*CFrame.new(0,-100,0)
        for _,id in ipairs(VOID_ASSETS) do
            stampRemote:InvokeServer(id,vCF,"{"..HttpService:GenerateGUID(false).."}",{target},1)
        end
        deleteRemote:InvokeServer(Instance.new("Model",nil))
    end
    task.wait(0.6) isLocking=false
end

