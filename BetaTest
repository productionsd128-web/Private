local function instantLock(target,myFolder,partName,finalPos)
    local ap=myFolder:FindFirstChild("ActiveParts")
    local tp=target.Character and target.Character:FindFirstChild(partName)
    if not tp then return end
    if not ap then ap=Instance.new("Folder") ap.Name="ActiveParts" ap.Parent=myFolder end
    local conn
    conn=ap.DescendantAdded:Connect(function(desc)
        if desc.Name=="Spikes" and desc:IsA("BasePart") and not desc:FindFirstChild("_u") then
            Instance.new("BoolValue",desc).Name="_u" conn:Disconnect()
            pcall(function() stampRemote:InvokeServer(56451715,finalPos,"{3ae31e60-5cd0-4d80-96b6-a1dd894ece8a}",{tp,desc},0) end)
        end
    end)
    local pp=myFolder:FindFirstChild("Plate")
    if pp then pcall(function() stampRemote:InvokeServer(41324904,pp.CFrame,"{fca81e11-1ead-4817-afde-4dc29e72ea1b}",{pp},0) end) end
    task.delay(0.6,function() if conn then conn:Disconnect() end end)
end

local function triggerDisform(target)
    if isDisforming then return end isDisforming=true
    local folder=getMyPlateFolder()
    if not folder or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then isDisforming=false return end
    local pp=folder:FindFirstChild("Plate")
    if not pp then isDisforming=false return end
    local vCF=CFrame.new(pp.Position.X,VOID_Y,pp.Position.Z)
    local mode=disModes[disModeIdx]
    if mode=="VERTICAL DETACH" then
        local vMap={["Left Leg"]=0,["Right Leg"]=0,["Torso"]=STRETCH_GAP,["Left Arm"]=STRETCH_GAP*1.5,["Right Arm"]=STRETCH_GAP*1.5,["Head"]=STRETCH_GAP*2}
        for limb,off in pairs(vMap) do task.spawn(instantLock,target,folder,limb,vCF*CFrame.new(0,off,0)) task.wait(0.04) end
    elseif mode=="ALL PARTS" then
        for _,limb in ipairs({"Head","Torso","Left Arm","Right Arm","Left Leg","Right Leg"}) do
            task.spawn(instantLock,target,folder,limb,vCF) task.wait(0.04)
        end
    else instantLock(target,folder,mode,vCF) end
    task.wait(disCooldown) isDisforming=false
end

