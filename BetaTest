local function bindToggle(pill,pillBg,icon,getter,setter,onColor)
    local function refresh()
        local on=getter()
        TweenService:Create(pillBg,TweenInfo.new(0.2),{BackgroundColor3=on and onColor or RED}):Play()
        TweenService:Create(icon,TweenInfo.new(0.2),{BackgroundColor3=on and onColor or SUBTEXT}):Play()
        pill.Text=on and "ON" or "OFF"
    end
    pill.MouseButton1Click:Connect(function() setter(not getter()) refresh() end)
    refresh()
end

