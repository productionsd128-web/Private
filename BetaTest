local cachedFolder = nil
local function getMyPlateFolder()
    if cachedFolder and cachedFolder.Parent then return cachedFolder end
    local pl = workspace:FindFirstChild("Plates")
    if not pl then return nil end
    for _,f in ipairs(pl:GetChildren()) do
        local o = f:FindFirstChild("Owner")
        if o and (tostring(o.Value)==lp.Name or tostring(o.Value)==tostring(lp.UserId)) then
            cachedFolder=f return f
        end
    end
end
local function getMyPlatePart()
    local f=getMyPlateFolder() return f and f:FindFirstChild("Plate")
end

