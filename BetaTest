    lbl.Font=Enum.Font.Gotham lbl.TextSize=11 lbl.TextXAlignment=Enum.TextXAlignment.Left

    local dot=Instance.new("Frame",card)
    dot.Size=UDim2.new(0,8,0,8) dot.Position=UDim2.new(1,-18,0.5,-4)
    dot.BackgroundColor3=SUBTEXT dot.BorderSizePixel=0
    Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0)

    local pulsing=false
    local function startP(color)
        dot.BackgroundColor3=color or ACCENT
        if pulsing then return end pulsing=true
        task.spawn(function()
            while pulsing do
                TweenService:Create(dot,TweenInfo.new(0.6,Enum.EasingStyle.Sine),{BackgroundTransparency=0.15,Size=UDim2.new(0,10,0,10),Position=UDim2.new(1,-19,0.5,-5)}):Play()
                task.wait(0.6)
                TweenService:Create(dot,TweenInfo.new(0.6,Enum.EasingStyle.Sine),{BackgroundTransparency=0.65,Size=UDim2.new(0,8,0,8),Position=UDim2.new(1,-18,0.5,-4)}):Play()
                task.wait(0.6)
            end
        end)
    end
    local function stopP()
        pulsing=false dot.BackgroundColor3=SUBTEXT dot.BackgroundTransparency=0
        dot.Size=UDim2.new(0,8,0,8) dot.Position=UDim2.new(1,-18,0.5,-4)
    end
    return lbl,startP,stopP
end

