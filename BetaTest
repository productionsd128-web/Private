-- MAIN HEARTBEAT
-----------------------------------------------------------
RunService.Heartbeat:Connect(function()
    local char=lp.Character
    local root=char and char:FindFirstChild("HumanoidRootPart")
    local anyOn=toolLockOn or bodyLockOn or disHboxOn or pushOn

    if root then
        ring.CFrame=root.CFrame
        ring.Transparency=(showHitbox and anyOn) and 0.88 or 1
    else ring.Transparency=1 return end

    local now=tick()

    if toolLockOn or bodyLockOn then
        for _,p in ipairs(Players:GetPlayers()) do
            if p==lp or not p.Character then continue end
            local pr=p.Character:FindFirstChild("HumanoidRootPart")
            if not pr then continue end
            if (root.Position-pr.Position).Magnitude>detectRange then continue end
            if toolLockOn then
                local tool=p.Character:FindFirstChildWhichIsA("Tool")
                if tool and spyTools[tool.Name] then
                    fireVoidStamp(tool:FindFirstChild("Handle") or tool:FindFirstChildWhichIsA("BasePart"))
                end
            end
            if bodyLockOn then fireVoidStamp(p.Character:FindFirstChild(currentVPart)) end
        end
    end

    if disOn then
        local t=resolvePlayer(disTargetText)
        if t and now-lastDis>=disCooldown then lastDis=now task.spawn(triggerDisform,t) end
    end
    if disHboxOn then
        for _,p in ipairs(Players:GetPlayers()) do
            if p==lp or not p.Character then continue end
            local pr=p.Character:FindFirstChild("HumanoidRootPart")
            if not pr then continue end
            if (root.Position-pr.Position).Magnitude<=detectRange then
                if now-lastDis>=disCooldown then lastDis=now task.spawn(triggerDisform,p) end
            end
        end
    end

    if pushOn then
        local single=resolvePlayer(pushTargetText)
        if single then
            if single.Character then
                local pr=single.Character:FindFirstChild("HumanoidRootPart")
                if pr and (root.Position-pr.Position).Magnitude<=detectRange then task.spawn(pushPlayer,single) end
            end
        else
            for _,p in ipairs(Players:GetPlayers()) do
                if p==lp or not p.Character then continue end
                local pr=p.Character:FindFirstChild("HumanoidRootPart")
                if not pr then continue end
                if (root.Position-pr.Position).Magnitude<=detectRange then task.spawn(pushPlayer,p) end
            end
        end
    end

    if abyssOn and now-lastAbyss>=ABYSS_CD then
        local single=resolvePlayer(abyssTargetText)
        if single then
            lastAbyss=now task.spawn(tripleAbyss,single)
        else
            for _,p in ipairs(Players:GetPlayers()) do
                if p==lp or not p.Character then continue end
                lastAbyss=now task.spawn(tripleAbyss,p)
            end
        end
    end
end)
