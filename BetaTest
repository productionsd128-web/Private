local function pushPlayer(target)
    if pushCooldowns[target] then return end pushCooldowns[target]=true
    local plate=getMyPlatePart() local char=target.Character
    if not char or not plate then pushCooldowns[target]=nil return end
    local tp=char:FindFirstChild(currentPushPart)
    if not tp then pushCooldowns[target]=nil return end
    local asset=PUSH_ASSETS[pushAssetIdx] pushAssetIdx=pushAssetIdx%#PUSH_ASSETS+1
    local pCF=CFrame.new(plate.Position.X+math.random(-15,15),plate.Position.Y-100,plate.Position.Z+math.random(-15,15))
        *CFrame.Angles(math.rad(math.random(360)),math.rad(math.random(360)),math.rad(math.random(360)))
    task.spawn(function()
        pcall(function() stampRemote:InvokeServer(asset,pCF,"{99ab22df-ca29-4143-a2fd-0a1b79db78c2}",{tp},0) end)
        task.wait(0.02)
        pcall(function() stampRemote:InvokeServer(asset,pCF,"{99ab22df-ca29-4143-a2fd-0a1b79db78c2}",{dummyHRP},0) end)
        task.wait(0.05) pushCooldowns[target]=nil
    end)
end

