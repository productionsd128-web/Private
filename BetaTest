local function resolvePlayer(text)
    text=text:lower():gsub("%s+","")
    if text=="" then return nil end
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=lp then
            if p.Name:lower():sub(1,#text)==text or p.DisplayName:lower():sub(1,#text)==text then
                return p
            end
        end
    end
end

