local function applyMovers(part,pos,isStick)
    local bp=part:FindFirstChild("BH_P") or Instance.new("BodyPosition")
    bp.Name="BH_P" bp.MaxForce=Vector3.new(9e9,9e9,9e9) bp.P=50000 bp.Position=pos bp.Parent=part
    local bav=part:FindFirstChild("BH_V") or Instance.new("BodyAngularVelocity")
    bav.Name="BH_V" bav.MaxTorque=Vector3.new(9e9,9e9,9e9)
    bav.AngularVelocity=isStick and Vector3.new(0,0,0) or Vector3.new(300,300,300) bav.Parent=part
end
local function cleanMovers(part)
    if part:FindFirstChild("BH_P") then part.BH_P:Destroy() end
    if part:FindFirstChild("BH_V") then part.BH_V:Destroy() end
end
task.spawn(function()
    while true do
        local isStick=lavaStickOn or lavaStickAllOn
        local isFling=lavaFlingOn or lavaFlingAllOn
        if isFling or isStick then
            local targets={}
            if lavaFlingAllOn or lavaStickAllOn then
                for _,p in ipairs(Players:GetPlayers()) do
                    if p~=lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        table.insert(targets,p.Character.HumanoidRootPart)
                    end
                end
            else
                local t=resolvePlayer(lavaTargetText)
                if t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") then
                    table.insert(targets,t.Character.HumanoidRootPart)
                end
            end
            if #targets>0 then
                for _,obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("BasePart") and not obj.Anchored and not obj:IsDescendantOf(lp.Character or Instance.new("Model")) then
                        local closest,minD=nil,math.huge
                        for _,tr in ipairs(targets) do
                            local d=(obj.Position-tr.Position).Magnitude
                            if d<minD then minD=d closest=tr end
                        end
                        if closest then applyMovers(obj,closest.Position+(closest.Velocity*0.25),isStick) end
                    end
                end
            end
        else
            for _,obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") then cleanMovers(obj) end
            end
        end
        task.wait(0.05)
    end
end)

